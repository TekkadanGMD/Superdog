# Redirecionamento 301 para Non-WWW e HTTPS (Hostinger/LiteSpeed)
<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # 1. Redirecionar WWW para Sem WWW
  RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
  RewriteRule ^(.*)$ https://%1/$1 [R=301,L]
  
  # 2. Forçar HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # 3. Cache Control para Assets (Opcional, melhora PageSpeed)
  <FilesMatch "\.(avif|webp|jpg|jpeg|png|gif|ico|svg|css|js)$">
    Header set Cache-Control "max-age=31536000, public"
  </FilesMatch>
</IfModule>
